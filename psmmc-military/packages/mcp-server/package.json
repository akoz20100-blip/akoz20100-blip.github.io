{
  "name": "@psmmc/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Remote MCP server for the PSMMC military hospital pharmacy stock, reorder & expiry dashboard. Lets anyone with Claude (desktop or phone) ask natural-language questions about the dashboard data.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "psmmc-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js --stdio",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http",
    "dev": "tsx watch src/index.ts --http",
    "dev:stdio": "tsx src/index.ts --stdio",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "papaparse": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/papaparse": "^5.3.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
