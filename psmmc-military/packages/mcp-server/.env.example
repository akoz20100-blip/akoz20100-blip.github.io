# ---------------------------------------------------------------------------
# PSMMC MCP server configuration
# Copy this file to `.env` (it is git-ignored) and fill in real values.
# ---------------------------------------------------------------------------

# Shared secret that protects the remote (HTTP) endpoint. REQUIRED for `start:http`
# (the server refuses to start without it unless PSMMC_ALLOW_NO_AUTH=1).
# Anyone you give this token to can query the dashboard, so treat it like a password.
# Generate a strong one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# (Leave this unset rather than shipping a guessable value — the example placeholder
#  string is explicitly rejected by the server.)
PSMMC_MCP_TOKEN=

# Local development ONLY: set to 1 to run the HTTP transport with no token.
# Never set this on an internet-reachable deploy.
# PSMMC_ALLOW_NO_AUTH=0

# Port for the HTTP transport (remote custom connector). Default: 8787
PORT=8787

# Bind address for the HTTP transport. Default: 0.0.0.0
HOST=0.0.0.0

# Optional. Public base URL of the deployed server. Set this so the startup log
# and the shareable connector URL use your real https host instead of localhost.
# PUBLIC_URL=https://psmmc-mcp.example.com

# Optional DNS-rebinding protection. Comma-separated allowlists for the Host and
# Origin headers. Leave empty to disable (typical when the server sits behind a
# trusted HTTPS reverse proxy). Set the public hostname(s) to lock it down.
# PSMMC_ALLOWED_HOSTS=psmmc-mcp.example.com,localhost:8787
# PSMMC_ALLOWED_ORIGINS=https://claude.ai

# Optional. Directory to load dashboard data from (CSV/JSON exports).
# If unset, the server looks in ./data, then falls back to a built-in synthetic dataset.
# Put REAL hospital exports in ./data/private/ (git-ignored) and point this there.
# PSMMC_DATA_DIR=./data/private
